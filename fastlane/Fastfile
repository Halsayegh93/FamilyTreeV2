default_platform(:ios)

platform :ios do

  # ─── Build ───────────────────────────────────────────────
  desc "Build the app (Debug)"
  lane :build do
    gym(
      project: "FamilyTreeV2.xcodeproj",
      scheme: "FamilyTreeV2",
      configuration: "Debug",
      destination: "platform=iOS Simulator,name=iPhone 16",
      skip_codesigning: true,
      skip_archive: true,
      clean: true
    )
  end

  # ─── Beta (TestFlight) ──────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :beta do
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || (latest_testflight_build_number + 1).to_s
    )

    gym(
      project: "FamilyTreeV2.xcodeproj",
      scheme: "FamilyTreeV2",
      configuration: "Release",
      export_method: "app-store",
      clean: true
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key: app_store_connect_api_key
    )
  end

  # ─── Release (App Store) ────────────────────────────────
  desc "Build and submit to App Store Review"
  lane :release do
    increment_build_number(
      build_number: (latest_testflight_build_number + 1).to_s
    )

    gym(
      project: "FamilyTreeV2.xcodeproj",
      scheme: "FamilyTreeV2",
      configuration: "Release",
      export_method: "app-store",
      clean: true
    )

    upload_to_app_store(
      submit_for_review: true,
      automatic_release: false,
      api_key: app_store_connect_api_key
    )
  end

  # ─── Helpers ────────────────────────────────────────────
  private_lane :app_store_connect_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
      is_key_content_base64: true
    )
  end

end
